{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "arrowParens": "always",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "objectWrap": "preserve",
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "**/__fixtures__/**",
    "**/*.md",
    "**/*.json",
    "**/*.yml",
    "**/*.yaml"
  ]
}
