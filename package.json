{
  "name": "@series-inc/blast-radius",
  "version": "0.1.3",
  "description": "Blast-radius tiered PR merge policy for AI-authored code — a deterministic classifier, bot workflows, and an agent skill, installable into any repo.",
  "keywords": [
    "pr",
    "code-review",
    "merge-policy",
    "blast-radius",
    "ai",
    "agents",
    "skills",
    "github-actions",
    "ci-cd"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jalbarran-series/blast-radius.git"
  },
  "homepage": "https://github.com/jalbarran-series/blast-radius#readme",
  "bugs": "https://github.com/jalbarran-series/blast-radius/issues",
  "bin": {
    "blast-radius": "cli/bin/cli.js"
  },
  "main": "./dist/engine/classify.mjs",
  "exports": {
    ".": "./dist/engine/classify.mjs",
    "./owners": "./dist/engine/ownersConfig.mjs"
  },
  "files": [
    "engine/",
    "!engine/**/*.test.ts",
    "!engine/__fixtures__/",
    "dist/",
    "cli/",
    "templates/",
    "skill/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run engine",
    "build": "node scripts/build-engine.mjs",
    "build:skills": "node scripts/build-skills.mjs",
    "prepack": "node scripts/build-engine.mjs",
    "prepare": "husky",
    "setup": "node cli/bin/cli.js install",
    "doctor": "node cli/bin/cli.js doctor",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "release": "commit-and-tag-version"
  },
  "dependencies": {
    "minimatch": "9.0.5",
    "yaml": "2.5.1"
  },
  "devDependencies": {
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "commit-and-tag-version": "12.7.3",
    "esbuild": "0.24.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "tsx": "4.19.2",
    "vitest": "2.1.8"
  }
}
