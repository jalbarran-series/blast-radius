{
  "name": "blast-radius",
  "version": "0.1.0",
  "description": "Blast-radius tiered PR merge policy for AI-authored code — a deterministic classifier, bot workflows, and an agent skill, installable into any repo.",
  "keywords": [
    "pr",
    "code-review",
    "merge-policy",
    "blast-radius",
    "ai",
    "agents",
    "skills",
    "github-actions",
    "ci-cd"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "blast-radius": "cli/bin/cli.js"
  },
  "main": "./dist/engine/classify.mjs",
  "exports": {
    ".": "./dist/engine/classify.mjs",
    "./owners": "./dist/engine/ownersConfig.mjs"
  },
  "files": [
    "engine/",
    "dist/",
    "cli/",
    "templates/",
    "skill/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run engine",
    "build": "node scripts/build-engine.mjs",
    "build:skills": "node scripts/build-skills.mjs",
    "prepack": "node scripts/build-engine.mjs",
    "setup": "node cli/bin/cli.js install",
    "doctor": "node cli/bin/cli.js doctor"
  },
  "dependencies": {
    "minimatch": "9.0.5",
    "yaml": "2.5.1"
  },
  "devDependencies": {
    "esbuild": "0.24.0",
    "tsx": "4.19.2",
    "vitest": "2.1.8"
  }
}
